# Test Environment Configuration
ENVIRONMENT=development

# Use SQLite for testing (no PostgreSQL required)
USE_SQLITE_FOR_TESTS=true

# Database Configuration (PostgreSQL - optional for testing)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wikipedia_intelligence_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password

# Redis Configuration (optional for testing)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=1

# API Configuration
WIKIMEDIA_API_BASE_URL=https://wikimedia.org/api/rest_v1
WIKIMEDIA_RATE_LIMIT=200

# Logging Configuration
LOG_LEVEL=INFO
